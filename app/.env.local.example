# Contineo App – env premenné
# Skopíruj tento súbor ako .env.local a doplň hodnoty
# NIKDY necommituj .env.local do Gitu

# ── MongoDB Atlas ──────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=contineo

# ── Voyage AI / MongoDB Atlas AI Models ───────────────────────────────────
# Získaš v Atlas UI: Services > AI Models > Create API Key
ATLAS_VOYAGE_KEY=

# ── Ollama (lokálny LLM) ───────────────────────────────────────────────────
# Spusti: ollama pull llama3.2
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Anthropic Claude API (fallback) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── NextAuth ───────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=<vygeneruj: openssl rand -base64 32>
NEXTAUTH_URL=http://localhost:3000

# ── Vercel Blob (úložisko PDF a obrázkov) ─────────────────────────────────
BLOB_READ_WRITE_TOKEN=
