{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Contineo codelist seed",
  "description": "Validačná schéma pre vzory číselníkov v app/src/codelists/*.json",
  "type": "object",
  "required": ["codelist", "closed", "items"],
  "properties": {
    "codelist": { "type": "string", "pattern": "^[a-zA-Z]+$" },
    "closed": { "type": "boolean" },
    "hierarchical": { "type": "boolean" },
    "description": { "type": "string" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key", "label"],
        "properties": {
          "key": { "type": "string", "pattern": "^[A-Za-z0-9_]+$" },
          "label": { "type": "string", "minLength": 1 },
          "parent": { "type": ["string", "null"] },
          "synonyms": { "type": "array", "items": { "type": "string" } },
          "sortOrder": { "type": "integer" },
          "isActive": { "type": "boolean" },
          "description": { "type": "string" },
          "note": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
